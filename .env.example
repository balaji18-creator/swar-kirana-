# ─────────────────────────────────────────────────────────────────
#  SWAR KIRANA — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# Gemini AI — Required for voice command parsing
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Vite exposes VITE_* vars to the browser bundle
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Firebase Client Config (for browser SDK)
# Firebase Console → Project Settings → Your Apps → Web
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_FIREBASE_DATABASE_ID="(default)"

# Firebase Server Config (for Express/Admin SDK)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_DATABASE_ID="(default)"

# App URL
APP_URL="http://localhost:3000"
